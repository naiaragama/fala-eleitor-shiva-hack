# === Servidor ===
PORT=3000

# === PostgreSQL ===
# Replit: DATABASE_URL é configurado automaticamente
# Local: configure manualmente
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fiscaliza_rj

# === Portal da Transparência ===
# Cadastre-se: https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_API_KEY=

# === Tess AI (Pareto) ===
# Cadastre-se: https://tess.pareto.io
# Docs: https://tess-dfe1edf0.mintlify.app
TESS_API_KEY=
TESS_AGENT_ID=

# === WhatsApp ===
# Opção 1: Meta Business API
WA_VERIFY_TOKEN=fiscaliza-rj-token
WA_API_TOKEN=
WA_PHONE_NUMBER_ID=

# Opção 2: Evolution API (open source)
WA_API_URL=
EVOLUTION_INSTANCE=fiscaliza
